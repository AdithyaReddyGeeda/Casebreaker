# Copy this file to ".env.local" in this same folder (casebreaker/game), then paste your key.
# Command line:  cp env.example .env.local
#
# Next.js only loads .env.local from the app root (the folder where you run `npm run dev`).

OPENAI_API_KEY=

# Optional:
# ANTHROPIC_API_KEY=
# INTERROGATION_LLM_PROVIDER=auto
# OPENAI_INTERROGATION_MODEL=gpt-4o-mini
