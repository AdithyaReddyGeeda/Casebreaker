# Copy this file to ".env.local" in this same folder (casebreaker/game), then paste your key.
# Command line:  cp env.example .env.local
#
# Next.js only loads .env.local from the app root (the folder where you run `npm run dev`).

OPENAI_API_KEY=

# Optional:
# ANTHROPIC_API_KEY=
# INTERROGATION_LLM_PROVIDER=auto
# OPENAI_INTERROGATION_MODEL=gpt-4o-mini
#
# Fixed max_tokens for interrogation (overrides dynamic stress/length heuristics when set to a number).
# INTERROGATION_MAX_OUTPUT_TOKENS=120
#
# Or send maxOutputTokens (64–256) in the JSON body to /api/interrogate from a custom client.
#
# Optional: models for POST /api/interrogate/suggest-followups (defaults mirror interrogation).
# OPENAI_SUGGEST_FOLLOWUPS_MODEL=gpt-4o-mini
# ANTHROPIC_SUGGEST_FOLLOWUPS_MODEL=claude-haiku-4-5-20251001
